# LocalVoice Configuration
# Copy to .env and customize as needed

# ─── Whisper STT (compat shim + whisper.cpp backends) ───
# Default model (multilingual): tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=medium
# English-only model for the second backend
WHISPER_MODEL_EN=small.en
# Device hint: vulkan (AMD iGPU) or cpu fallback
WHISPER_DEVICE=vulkan
# Compute type compatibility hint (kept for API compatibility)
WHISPER_COMPUTE_TYPE=int8
# CPU threads for inference
WHISPER_THREADS=4

# ─── Piper TTS (fast, real-time) ──────────────────
# Voice model name (see: https://rhasspy.github.io/piper-samples/)
PIPER_VOICE=en_US-lessac-medium

# ─── Parler-TTS (high quality, slow) ─────────────
# Only used with: docker compose --profile quality-tts up
PARLER_MODEL=parler-tts/parler_tts_mini_v0.1
PARLER_DESCRIPTION=A female speaker delivers a slightly expressive and animated speech.
PARLER_THREADS=6

# ─── 3CX Integration ─────────────────────────────
# PBX fully qualified domain name
THREECX_FQDN=your-pbx.example.com
# OAuth2 client credentials (from 3CX Admin > Integrations > API)
THREECX_CLIENT_ID=your-client-id
THREECX_CLIENT_SECRET=your-client-secret
# API key for Call Control API (3cx-call CLI)
THREECX_API_KEY=your-api-key
# Default DN/extension for call control
THREECX_DN=100

# ─── Recording Sync ──────────────────────────────
# Cron schedule for recording sync (default: every 15 minutes)
SYNC_CRON_SCHEDULE=*/15 * * * *
# Run sync immediately on container start
SYNC_ON_START=false
