# -- Auth (env-var based for Docker) -------------------------------------------

def load_config():
    """Load config from environment variables."""
    config = {
        "fqdn": os.environ.get("THREECX_FQDN", ""),
        "client_id": os.environ.get("THREECX_CLIENT_ID", ""),
        "client_secret": os.environ.get("THREECX_CLIENT_SECRET", ""),
    }
    if not config["fqdn"]:
        print("Error: THREECX_FQDN environment variable not set", file=sys.stderr)
        sys.exit(1)
    return config

def save_config(config):
    """No-op: config lives in environment, not on disk."""
    pass

def get_token(fqdn, client_id, client_secret):
    url = f"https://{fqdn}/connect/token"
    data = {
        "client_id": client_id,
        "client_secret": client_secret,
        "grant_type": "client_credentials"
    }
    resp = requests.post(url, data=data)
    resp.raise_for_status()
    return resp.json()

_token_cache = {}

def get_headers(config):
    now = time.time()
    if _token_cache.get("access_token") and _token_cache.get("token_expiry", 0) > now + 5:
        token = _token_cache["access_token"]
    else:
        token_data = get_token(config["fqdn"], config["client_id"], config["client_secret"])
        _token_cache["access_token"] = token_data["access_token"]
        _token_cache["token_expiry"] = now + token_data.get("expires_in", 3600)
        token = _token_cache["access_token"]
    return {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}

def api_url(config, path):
    return f"https://{config['fqdn']}/xapi/v1/{path}"

# -- SQLite Setup --------------------------------------------------------------

DB_PATH = os.environ.get("DB_PATH", "/data/3cx.db3")
RECORDINGS_DIR = os.environ.get("RECORDINGS_DIR", "/data/recordings")

def init_db():
    os.makedirs(RECORDINGS_DIR, exist_ok=True)
    db = sqlite3.connect(DB_PATH)
    db.execute("PRAGMA journal_mode=WAL")
    db.execute("""
        CREATE TABLE IF NOT EXISTS recordings (
            id                    INTEGER PRIMARY KEY,
            start_time            TEXT,
            end_time              TEXT,
            duration              INTEGER,
            participant_names     TEXT,
            direction             TEXT,
            transcription         TEXT,
            summary               TEXT,
            sentiment_score       REAL,
            can_be_transcribed    INTEGER,
            is_transcribed        INTEGER,
            transcription_result  TEXT,
            wav_path              TEXT,
            wav_downloaded_at     TEXT,
            wav_size_bytes        INTEGER,
            local_transcription   TEXT,
            local_language        TEXT,
            local_duration        REAL,
            local_transcribed_at  TEXT,
            sync_status           TEXT DEFAULT 'pending',
            error_message         TEXT,
            created_at            TEXT DEFAULT (datetime('now')),
            updated_at            TEXT DEFAULT (datetime('now'))
        )
    """)
    # Migrate: add columns for Opus, speaker metadata, segments, model
    migrations = [
        "ALTER TABLE recordings ADD COLUMN opus_path TEXT",
        "ALTER TABLE recordings ADD COLUMN opus_size_bytes INTEGER",
        "ALTER TABLE recordings ADD COLUMN from_display_name TEXT",
        "ALTER TABLE recordings ADD COLUMN to_display_name TEXT",
        "ALTER TABLE recordings ADD COLUMN from_caller_number TEXT",
        "ALTER TABLE recordings ADD COLUMN to_caller_number TEXT",
        "ALTER TABLE recordings ADD COLUMN call_type TEXT",
        "ALTER TABLE recordings ADD COLUMN segments_json TEXT",
        "ALTER TABLE recordings ADD COLUMN local_model TEXT",
        "ALTER TABLE recordings ADD COLUMN diarization_json TEXT",
        "ALTER TABLE recordings ADD COLUMN speaker_map_json TEXT",
        "ALTER TABLE recordings ADD COLUMN diarized_at TEXT",
        "ALTER TABLE recordings ADD COLUMN sync_status_diar TEXT DEFAULT 'pending'",
        "ALTER TABLE recordings ADD COLUMN call_log_json TEXT",
        "ALTER TABLE recordings ADD COLUMN call_log_synced INTEGER DEFAULT 0",
        "ALTER TABLE recordings ADD COLUMN processing_step TEXT",
    ]
    for sql in migrations:
        try:
            db.execute(sql)
        except sqlite3.OperationalError:
            pass  # column already exists
    db.commit()
    return db

# -- Transliteration (Devanagari -> Latin) -------------------------------------

def transliterate_text(text):
    """Convert any Devanagari characters in text to readable Latin script."""
    if not text or not any('\u0900' <= c <= '\u097F' for c in text):
        return text  # No Devanagari, skip
    return sanscript.transliterate(text, sanscript.DEVANAGARI, sanscript.ITRANS)

def resolve_audio_file(opus_path, wav_path):
    """Return (abs_path, mime_type) preferring opus over WAV, or (None, None)."""
    if opus_path:
        p = os.path.join(RECORDINGS_DIR, opus_path)
        if os.path.exists(p):
            return p, "audio/ogg"
    if wav_path:
        p = os.path.join(RECORDINGS_DIR, wav_path)
        if os.path.exists(p):
            return p, "audio/wav"
    return None, None

# -- Phase 1: Fetch Metadata ---------------------------------------------------

def fetch_all_recordings(config, db):
    print("[1/4] Fetching recording metadata...")
    headers = get_headers(config)
    skip = 0
    top = 100
    total_new = 0
    total_existing = 0

    while True:
        params = {"$top": top, "$skip": skip, "$orderby": "Id"}
        resp = requests.get(api_url(config, "Recordings"), headers=headers, params=params)
        resp.raise_for_status()
        data = resp.json()
        records = data.get("value", [])

        if not records:
            break

        for rec in records:
            rec_id = rec.get("Id")
            if rec_id is None:
                continue

            participants = rec.get("ParticipantNames")
            if isinstance(participants, list):
                participants = ", ".join(participants)

            cursor = db.execute(
                "INSERT OR IGNORE INTO recordings (id, start_time, end_time, duration, "
                "participant_names, direction, transcription, summary, sentiment_score, "
                "can_be_transcribed, is_transcribed, transcription_result, "
                "from_display_name, to_display_name, from_caller_number, to_caller_number, call_type) "
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)",
                (
                    rec_id,
                    rec.get("StartTime"),
                    rec.get("EndTime"),
                    rec.get("Duration"),
                    participants,
                    rec.get("Direction"),
                    rec.get("Transcription"),
                    rec.get("Summary"),
                    rec.get("SentimentScore"),
                    1 if rec.get("CanBeTranscribed") else 0,
                    1 if rec.get("IsTranscribed") else 0,
                    rec.get("TranscriptionResult"),
                    rec.get("FromDisplayName"),
                    rec.get("ToDisplayName"),
                    rec.get("FromCallerNumber"),
                    rec.get("ToCallerNumber"),
                    rec.get("CallType"),
                )
            )
            if cursor.rowcount > 0:
                total_new += 1
            else:
                # Backfill speaker metadata for existing rows missing it
                db.execute(
                    "UPDATE recordings SET from_display_name=COALESCE(from_display_name, ?), "
                    "to_display_name=COALESCE(to_display_name, ?), "
                    "from_caller_number=COALESCE(from_caller_number, ?), "
                    "to_caller_number=COALESCE(to_caller_number, ?), "
                    "call_type=COALESCE(call_type, ?) WHERE id=?",
                    (
                        rec.get("FromDisplayName"),
                        rec.get("ToDisplayName"),
                        rec.get("FromCallerNumber"),
                        rec.get("ToCallerNumber"),
                        rec.get("CallType"),
                        rec_id,
                    )
                )
                total_existing += 1

        db.commit()
        print(f"  Fetched {skip + len(records)} recordings so far ({total_new} new, {total_existing} existing)")

        if len(records) < top:
            break
        skip += top
        headers = get_headers(config)  # refresh token if needed

    print(f"  Done: {total_new} new recordings added, {total_existing} already in DB")
    return total_new

# -- Phase 1.5: Fetch Call Logs ------------------------------------------------

DN_TYPE_LABELS = {
    0: "Extension", 1: "External", 4: "Queue", 5: "Voicemail",
    6: "IVR", 7: "Fax", 8: "Parking", 16: "Group",
}

def normalize_number(num):
    """Strip non-digit chars, keep last 10 digits for comparison."""
    if not num:
        return ""
    digits = re.sub(r'\D', '', str(num))
    return digits[-10:] if len(digits) >= 10 else digits

def numbers_match(a, b):
    """Check if two normalized numbers match (exact or last-7-digit suffix)."""
    if not a or not b:
        return False
    if a == b:
        return True
    # Suffix match for shorter numbers (extensions, local numbers)
    min_len = min(len(a), len(b))
    suffix = min(7, min_len)
    return suffix >= 3 and a[-suffix:] == b[-suffix:]

def fetch_call_logs(config, db):
    """Fetch call log data from 3CX for recordings that don't have it yet."""
    # Reset previously failed syncs (marked synced but no data) so they get retried
    reset_count = db.execute(
        "SELECT COUNT(*) FROM recordings "
        "WHERE call_log_synced=1 AND call_log_json IS NULL"
    ).fetchone()[0]
    if reset_count > 0:
        db.execute(
            "UPDATE recordings SET call_log_synced=0 "
            "WHERE call_log_synced=1 AND call_log_json IS NULL"
        )
        db.commit()
        print(f"  Reset {reset_count} recordings for call log retry (previously unmatched)")

    rows = db.execute(
        "SELECT id, start_time, end_time, from_caller_number, to_caller_number "
        "FROM recordings WHERE (call_log_synced = 0 OR call_log_synced IS NULL) "
        "AND start_time IS NOT NULL ORDER BY start_time"
    ).fetchall()

    if not rows:
        print("  No recordings need call log data")
        return 0

    print(f"  {len(rows)} recordings to fetch call logs for")

    # Group recordings by date to batch API calls
    by_date = defaultdict(list)
    for rec_id, start_time, end_time, from_num, to_num in rows:
        try:
            dt = datetime.fromisoformat(start_time.replace("Z", "+00:00"))
            date_key = dt.strftime("%Y-%m-%d")
        except (ValueError, AttributeError):
            continue
        by_date[date_key].append({
            "id": rec_id, "start": start_time, "end": end_time,
            "from_num": from_num or "", "to_num": to_num or "",
        })

    matched = 0
    for date_key, recs in sorted(by_date.items()):
        try:
            # Query call logs for this entire day (OData bound function with all required params)
            period_from = f"{date_key}T00:00:00Z"
            period_to = f"{date_key}T23:59:59Z"
            headers = get_headers(config)

            odata_fn = (
                f"ReportCallLogData/Pbx.GetCallLogData("
                f"periodFrom={period_from},"
                f"periodTo={period_to},"
                f"sourceType=0,sourceFilter='',"
                f"destinationType=0,destinationFilter='',"
                f"callsType=0,callTimeFilterType=0,"
                f"callTimeFilterFrom='0:00:0',callTimeFilterTo='0:00:0',"
                f"hidePcalls=true)"
            )
            resp = requests.get(
                api_url(config, odata_fn), headers=headers,
                params={"$top": "1000", "$orderby": "StartTime"},
            )
            resp.raise_for_status()
            data = resp.json()
            log_entries = data.get("value", [])

            if not log_entries:
                # Mark all recordings for this date as synced (no logs found)
                for rec in recs:
                    db.execute(
                        "UPDATE recordings SET call_log_synced=1, updated_at=datetime('now') WHERE id=?",
                        (rec["id"],)
                    )
                db.commit()
                continue

            # Match log entries to recordings — prefer direct RecId match, fall back to number+time
            for rec in recs:
                matching_logs = []

                # Strategy 1: Direct match via SrcRecId / DstRecId (most reliable)
                for entry in log_entries:
                    src_rec_id = entry.get("SrcRecId")
                    dst_rec_id = entry.get("DstRecId")
                    if src_rec_id == rec["id"] or dst_rec_id == rec["id"]:
                        matching_logs.append(entry)

                # Strategy 2: Fall back to time window + normalized number matching
                if not matching_logs:
                    try:
                        rec_start = datetime.fromisoformat(rec["start"].replace("Z", "+00:00"))
                        rec_end_str = rec["end"]
                        rec_end = datetime.fromisoformat(rec_end_str.replace("Z", "+00:00")) if rec_end_str else rec_start + timedelta(hours=1)
                    except (ValueError, AttributeError):
                        db.execute("UPDATE recordings SET call_log_synced=1 WHERE id=?", (rec["id"],))
                        continue

                    window_start = rec_start - timedelta(seconds=60)
                    window_end = rec_end + timedelta(seconds=60)
                    norm_from = normalize_number(rec["from_num"])
                    norm_to = normalize_number(rec["to_num"])

                    for entry in log_entries:
                        try:
                            entry_start_str = entry.get("StartTime", "")
                            entry_start = datetime.fromisoformat(entry_start_str.replace("Z", "+00:00"))
                        except (ValueError, AttributeError):
                            continue

                        if window_start <= entry_start <= window_end:
                            entry_src = str(entry.get("SourceDn", entry.get("SourceCallerId", "")))
                            entry_dst = str(entry.get("DestinationDn", entry.get("DestinationCallerId", "")))
                            norm_src = normalize_number(entry_src)
                            norm_dst = normalize_number(entry_dst)

                            if not norm_from and not norm_to:
                                continue
                            if (norm_from and (numbers_match(norm_from, norm_src) or numbers_match(norm_from, norm_dst))) or \
                               (norm_to and (numbers_match(norm_to, norm_src) or numbers_match(norm_to, norm_dst))):
                                matching_logs.append(entry)

                if matching_logs:
                    db.execute(
                        "UPDATE recordings SET call_log_json=?, call_log_synced=1, "
                        "updated_at=datetime('now') WHERE id=?",
                        (json.dumps(matching_logs), rec["id"])
                    )
                    matched += 1
                else:
                    if log_entries:
                        print(f"    WARN: No match for rec {rec['id']} "
                              f"(from={rec['from_num']}, to={rec['to_num']}) "
                              f"against {len(log_entries)} log entries")
                    db.execute(
                        "UPDATE recordings SET call_log_synced=1, updated_at=datetime('now') WHERE id=?",
                        (rec["id"],)
                    )

            db.commit()
            date_matched = sum(1 for r in recs if db.execute(
                "SELECT call_log_json FROM recordings WHERE id=? AND call_log_json IS NOT NULL", (r["id"],)
            ).fetchone())
            print(f"  Date {date_key}: {len(log_entries)} log entries, {date_matched}/{len(recs)} recordings matched")

        except Exception as e:
            print(f"  ERROR fetching call logs for {date_key}: {e}", file=sys.stderr)
            # Don't mark as synced on error — will retry next time
            continue

    db.commit()
    print(f"  Done: {matched} recordings enriched with call log data")
    return matched

# -- Phase 2: Download WAVs ----------------------------------------------------

def download_recordings(config, db):
    print("\n[2/4] Downloading WAV files...")
    rows = db.execute(
        "SELECT id FROM recordings WHERE sync_status = 'pending' ORDER BY id"
    ).fetchall()

    if not rows:
        print("  No pending downloads")
        return 0

    print(f"  {len(rows)} recordings to download")
    downloaded = 0

    for i, (rec_id,) in enumerate(rows, 1):
        wav_path = os.path.join(RECORDINGS_DIR, f"recording_{rec_id}.wav")
        rel_path = f"recording_{rec_id}.wav"  # stored in DB as relative

        # Mark as actively downloading
        db.execute("UPDATE recordings SET processing_step='downloading' WHERE id=?", (rec_id,))
        db.commit()

        try:
            headers = get_headers(config)
            resp = requests.get(
                api_url(config, f"Recordings/Pbx.DownloadRecording(recId={rec_id})"),
                headers=headers,
                timeout=120
            )
            resp.raise_for_status()

            with open(wav_path, "wb") as f:
                f.write(resp.content)

            file_size = os.path.getsize(wav_path)
            now_str = datetime.now(timezone.utc).isoformat()

            if file_size == 0:
                db.execute(
                    "UPDATE recordings SET processing_step=NULL, sync_status='error', error_message='Empty WAV file', "
                    "wav_path=?, wav_downloaded_at=?, wav_size_bytes=0, updated_at=datetime('now') "
                    "WHERE id=?",
                    (rel_path, now_str, rec_id)
                )
            else:
                db.execute(
                    "UPDATE recordings SET processing_step=NULL, sync_status='downloaded', wav_path=?, "
                    "wav_downloaded_at=?, wav_size_bytes=?, updated_at=datetime('now') WHERE id=?",
                    (rel_path, now_str, file_size, rec_id)
                )
            db.commit()
            downloaded += 1
            print(f"  [{i}/{len(rows)}] Downloaded recording {rec_id} ({file_size} bytes)")

        except Exception as e:
            db.execute(
                "UPDATE recordings SET processing_step=NULL, sync_status='error', error_message=?, "
                "updated_at=datetime('now') WHERE id=?",
                (f"Download failed: {e}", rec_id)
            )
            db.commit()
            print(f"  [{i}/{len(rows)}] ERROR downloading recording {rec_id}: {e}", file=sys.stderr)

    print(f"  Done: {downloaded}/{len(rows)} downloaded successfully")
    return downloaded

# -- Phase 2.5: Convert WAV -> Opus (parallel) ---------------------------------

def _convert_single(rec_id, wav_path):
    """Convert a single WAV to Opus. Returns (rec_id, opus_filename, opus_size, wav_size) or None."""
    opus_filename = wav_path.replace(".wav", ".opus")
    abs_wav = os.path.join(RECORDINGS_DIR, wav_path)
    abs_opus = os.path.join(RECORDINGS_DIR, opus_filename)

    if not os.path.exists(abs_wav):
        return None

    result = subprocess.run(
        ["ffmpeg", "-y", "-i", abs_wav, "-c:a", "libopus", "-b:a", "32k",
         "-vbr", "on", "-application", "voip", abs_opus],
        capture_output=True, text=True, timeout=120
    )
    if result.returncode != 0:
        raise RuntimeError(f"ffmpeg exit {result.returncode}: {result.stderr.strip()[:200]}")

    wav_size = os.path.getsize(abs_wav)
    os.remove(abs_wav)
    return (rec_id, opus_filename, os.path.getsize(abs_opus), wav_size)

def convert_to_opus(db, max_workers=4):
    print("\n[3/4] Converting WAVs to Opus...")
    rows = db.execute(
        "SELECT id, wav_path FROM recordings "
        "WHERE wav_path IS NOT NULL AND opus_path IS NULL "
        "AND sync_status IN ('downloaded', 'transcribed') ORDER BY id"
    ).fetchall()

    if not rows:
        print("  No recordings to convert")
        return 0

    print(f"  {len(rows)} recordings to convert ({max_workers} workers)")
    converted = 0

    # Mark all as converting before starting parallel work
    for rid, _ in rows:
        db.execute("UPDATE recordings SET processing_step='converting' WHERE id=?", (rid,))
    db.commit()

    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = {executor.submit(_convert_single, rid, wp): rid for rid, wp in rows}
        for future in as_completed(futures):
            rec_id = futures[future]
            try:
                result = future.result()
                if result is None:
                    db.execute("UPDATE recordings SET processing_step=NULL WHERE id=?", (rec_id,))
                    db.commit()
                    print(f"  SKIP: WAV missing for recording {rec_id}", file=sys.stderr)
                    continue
                _, opus_filename, opus_size, wav_size = result
                ratio = wav_size / opus_size if opus_size > 0 else 0
                db.execute(
                    "UPDATE recordings SET processing_step=NULL, opus_path=?, opus_size_bytes=?, updated_at=datetime('now') WHERE id=?",
                    (opus_filename, opus_size, rec_id)
                )
                db.commit()
                converted += 1
                print(f"  Converted {rec_id}: {wav_size}->{opus_size} bytes ({ratio:.0f}x)")
            except Exception as e:
                db.execute("UPDATE recordings SET processing_step=NULL WHERE id=?", (rec_id,))
                db.commit()
                print(f"  ERROR converting {rec_id}: {e}", file=sys.stderr)

    print(f"  Done: {converted}/{len(rows)} converted successfully")
    return converted

# -- Phase 3: Transcribe -------------------------------------------------------

LOCALVOICE_STT_URL = os.environ.get("LOCALVOICE_STT_URL", "http://whisper-stt:8000")
LOCALVOICE_API = f"{LOCALVOICE_STT_URL}/v1/audio/transcriptions"

def transcribe_recordings(db):
    print("\n[4/4] Transcribing recordings via Whisper API...")
    rows = db.execute(
        "SELECT id, wav_path, opus_path, call_type FROM recordings WHERE sync_status = 'downloaded' ORDER BY id"
    ).fetchall()

    if not rows:
        print("  No recordings to transcribe")
        return 0

    print(f"  {len(rows)} recordings to transcribe")
    transcribed = 0

    for i, (rec_id, wav_path, opus_path, call_type_val) in enumerate(rows, 1):
        audio_file, audio_mime = resolve_audio_file(opus_path, wav_path)

        if not audio_file:
            db.execute(
                "UPDATE recordings SET sync_status='error', error_message='No audio file found', "
                "updated_at=datetime('now') WHERE id=?",
                (rec_id,)
            )
            db.commit()
            print(f"  [{i}/{len(rows)}] ERROR: No audio for recording {rec_id}", file=sys.stderr)
            continue

        # Mark as actively transcribing
        db.execute("UPDATE recordings SET processing_step='transcribing' WHERE id=?", (rec_id,))
        db.commit()

        try:
            with open(audio_file, "rb") as f:
                # Determine model based on call_type
                call_type_str = call_type_val or ""
                if "Internal" in call_type_str or "Local" in call_type_str:
                    model_name = "Systran/faster-whisper-large-v3"
                else:
                    model_name = "Systran/faster-whisper-small.en"

                form_data = {"model": model_name, "response_format": "verbose_json"}
                if model_name != "small.en":
                    form_data["language"] = "hi"

                resp = requests.post(
                    LOCALVOICE_API,
                    files={"file": (os.path.basename(audio_file), f, audio_mime)},
                    data=form_data,
                    timeout=600
                )
            resp.raise_for_status()
            data = resp.json()
            now_str = datetime.now(timezone.utc).isoformat()

            # Transliterate Devanagari -> Latin
            text = transliterate_text(data.get("text", ""))
            segments = data.get("segments", [])
            for seg in segments:
                seg["text"] = transliterate_text(seg.get("text", ""))

            db.execute(
                "UPDATE recordings SET processing_step=NULL, local_transcription=?, segments_json=?, local_language=?, "
                "local_duration=?, local_transcribed_at=?, local_model=?, sync_status='transcribed', "
                "updated_at=datetime('now') WHERE id=?",
                (
                    text,
                    json.dumps(segments) if segments else None,
                    data.get("language"),
                    data.get("duration"),
                    now_str,
                    model_name,
                    rec_id
                )
            )
            db.commit()
            transcribed += 1
            text_preview = text[:60]
            print(f"  [{i}/{len(rows)}] Transcribed recording {rec_id} ({len(segments)} segments): {text_preview}...")

        except requests.Timeout:
            db.execute(
                "UPDATE recordings SET processing_step=NULL, sync_status='error', error_message='Transcription timed out', "
                "updated_at=datetime('now') WHERE id=?",
                (rec_id,)
            )
            db.commit()
            print(f"  [{i}/{len(rows)}] ERROR: Transcription timeout for recording {rec_id}", file=sys.stderr)

        except Exception as e:
            db.execute(
                "UPDATE recordings SET processing_step=NULL, sync_status='error', error_message=?, "
                "updated_at=datetime('now') WHERE id=?",
                (f"Transcription failed: {e}", rec_id)
            )
            db.commit()
            print(f"  [{i}/{len(rows)}] ERROR transcribing recording {rec_id}: {e}", file=sys.stderr)

    print(f"  Done: {transcribed}/{len(rows)} transcribed successfully")
    return transcribed

# -- Phase 5: Diarize and Identify Speakers ------------------------------------

LOCALVOICE_DIAR_URL = os.environ.get("LOCALVOICE_DIAR_URL", "http://diarization:8090")

def merge_diarization_with_transcription(whisper_segments, diar_segments, speaker_map):
    """Assign speaker labels to Whisper transcription segments based on diarization overlap."""
    for w_seg in whisper_segments:
        w_start = w_seg.get("start", 0)
        w_end = w_seg.get("end", 0)

        best_speaker = None
        best_overlap = 0

        for d_seg in diar_segments:
            d_start = d_seg.get("start", 0)
            d_end = d_seg.get("end", 0)
            overlap = max(0, min(w_end, d_end) - max(w_start, d_start))
            if overlap > best_overlap:
                best_overlap = overlap
                best_speaker = d_seg.get("speaker_label", d_seg.get("speaker"))

        if best_speaker and best_speaker in speaker_map:
            info = speaker_map[best_speaker]
            name = info.get("name") if isinstance(info, dict) else None
            w_seg["speaker"] = name if name else best_speaker
        elif best_speaker:
            w_seg["speaker"] = best_speaker

    return whisper_segments

def diarize_recordings(db):
    print("\n[5/5] Diarizing recordings...")
    rows = db.execute(
        "SELECT id, opus_path, wav_path, call_type FROM recordings "
        "WHERE sync_status = 'transcribed' AND (sync_status_diar = 'pending' OR sync_status_diar IS NULL) "
        "ORDER BY id"
    ).fetchall()

    if not rows:
        print("  No recordings to diarize")
        return 0

    print(f"  {len(rows)} recordings to diarize")
    diarized = 0

    for i, (rec_id, opus_path, wav_path, call_type) in enumerate(rows, 1):
        audio_file, audio_mime = resolve_audio_file(opus_path, wav_path)

        if not audio_file:
            continue

        # Mark as actively diarizing
        db.execute("UPDATE recordings SET processing_step='diarizing' WHERE id=?", (rec_id,))
        db.commit()

        try:
            # Determine speaker count hint from 3CX participant metadata
            participants = db.execute(
                "SELECT participant_names FROM recordings WHERE id=?", (rec_id,)
            ).fetchone()
            participant_count = None
            if participants and participants[0]:
                names = [n.strip() for n in participants[0].split(",") if n.strip()]
                participant_count = len(names) if names else None

            diar_data = {}
            if participant_count and participant_count >= 2:
                # Use as max_speakers hint, not hard constraint
                diar_data["max_speakers"] = str(participant_count)
            else:
                # Default hint for typical phone calls
                diar_data["max_speakers"] = "2"

            with open(audio_file, "rb") as f:
                resp = requests.post(
                    f"{LOCALVOICE_DIAR_URL}/diarize-and-identify",
                    files={"file": (os.path.basename(audio_file), f, audio_mime)},
                    data=diar_data,
                    timeout=600
                )
            resp.raise_for_status()
            data = resp.json()

            diar_segments = data.get("segments", [])
            speaker_map = data.get("speakers", {})

            # Map diarized speakers to 3CX caller metadata for 2-speaker calls
            speaker_labels = list(dict.fromkeys(
                s.get("speaker_label") or s.get("speaker", "") for s in diar_segments
            ))
            speaker_labels = [l for l in speaker_labels if l]

            rec_meta = db.execute(
                "SELECT from_display_name, to_display_name, call_type FROM recordings WHERE id=?",
                (rec_id,)
            ).fetchone()

            if (len(speaker_labels) == 2 and rec_meta
                    and rec_meta[0] and rec_meta[1]):
                from_name, to_name, rec_call_type = rec_meta
                # Only apply if no enrolled speaker names exist
                has_enrolled = any(
                    isinstance(speaker_map.get(l), dict) and speaker_map[l].get("name")
                    for l in speaker_labels
                )
                if not has_enrolled:
                    # Find which speaker talks first
                    first_by_label = {}
                    for seg in diar_segments:
                        label = seg.get("speaker_label") or seg.get("speaker", "")
                        if label and label not in first_by_label:
                            first_by_label[label] = seg.get("start", 0)
                    sorted_labels = sorted(speaker_labels, key=lambda l: first_by_label.get(l, 0))

                    # Heuristic: inbound calls → answerer (to) speaks first
                    is_inbound = "inbound" in (rec_call_type or "").lower()
                    first_name = to_name if is_inbound else from_name
                    second_name = from_name if is_inbound else to_name

                    for l in speaker_labels:
                        if l not in speaker_map or not isinstance(speaker_map[l], dict):
                            speaker_map[l] = {}
                    speaker_map[sorted_labels[0]]["name"] = first_name
                    speaker_map[sorted_labels[1]]["name"] = second_name

            db.execute(
                "UPDATE recordings SET processing_step=NULL, diarization_json=?, speaker_map_json=?, "
                "diarized_at=datetime('now'), sync_status_diar='diarized', "
                "updated_at=datetime('now') WHERE id=?",
                (
                    json.dumps(diar_segments),
                    json.dumps(speaker_map),
                    rec_id
                )
            )

            # Merge speaker names into existing transcription segments
            existing_segments = db.execute(
                "SELECT segments_json FROM recordings WHERE id=?", (rec_id,)
            ).fetchone()
            if existing_segments and existing_segments[0]:
                segments = json.loads(existing_segments[0])
                segments = merge_diarization_with_transcription(
                    segments, diar_segments, speaker_map
                )
                db.execute(
                    "UPDATE recordings SET segments_json=?, updated_at=datetime('now') WHERE id=?",
                    (json.dumps(segments), rec_id)
                )

            db.commit()
            diarized += 1
            speakers_info = data.get("speakers", {})
            names = [v.get("name", "?") for v in speakers_info.values() if isinstance(v, dict)]
            print(f"  [{i}/{len(rows)}] Diarized recording {rec_id}: {len(data.get('segments', []))} segments, speakers: {names}")

        except Exception as e:
            db.execute(
                "UPDATE recordings SET processing_step=NULL, sync_status_diar='error', "
                "updated_at=datetime('now') WHERE id=?",
                (rec_id,)
            )
            db.commit()
            print(f"  [{i}/{len(rows)}] ERROR diarizing recording {rec_id}: {e}", file=sys.stderr)

    print(f"  Done: {diarized}/{len(rows)} diarized successfully")
    return diarized

# -- Main ----------------------------------------------------------------------

def main():
    config = load_config()

    db = init_db()

    # Clear stale processing_step values from previous sync that may have crashed
    db.execute("UPDATE recordings SET processing_step=NULL WHERE processing_step IS NOT NULL")
    db.commit()

    try:
        fetch_all_recordings(config, db)

        # Phase 1.5: Enrich recordings with call log data
        print("\n[1.5/5] Fetching call log data...")
        try:
            fetch_call_logs(config, db)
        except Exception as e:
            print(f"  Call log fetch failed (non-fatal): {e}", file=sys.stderr)

        download_recordings(config, db)
        convert_to_opus(db)
        transcribe_recordings(db)

        # Phase 5: Diarize (optional — only if diarization service is available)
        try:
            diar_health = requests.get(f"{LOCALVOICE_DIAR_URL}/health", timeout=5)
            if diar_health.ok and diar_health.json().get("status") == "healthy":
                diarize_recordings(db)
            else:
                print("\n[5/5] Diarization service not healthy, skipping")
        except requests.ConnectionError:
            print("\n[5/5] Diarization service not available, skipping")
        except Exception as e:
            print(f"\n[5/5] Diarization check failed: {e}, skipping")

        # Summary
        print("\n-- Summary --")
        for row in db.execute(
            "SELECT sync_status, COUNT(*) FROM recordings GROUP BY sync_status ORDER BY sync_status"
        ):
            print(f"  {row[0]}: {row[1]}")
    finally:
        db.close()

if __name__ == "__main__":
    main()
