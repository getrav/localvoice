#!/usr/bin/env python3
"""3CX Configuration REST API CLI Tool"""

import argparse
import json
import os
import sys
import time
import requests
from urllib.parse import urljoin

CONFIG_FILE = os.environ.get("THREECX_CONFIG_FILE", os.path.expanduser("~/.3cx-config.json"))

def load_config():
    """Load config from environment variables, falling back to config file."""
    fqdn = os.environ.get("THREECX_FQDN", "")
    if fqdn:
        return {
            "fqdn": fqdn,
            "client_id": os.environ.get("THREECX_CLIENT_ID", ""),
            "client_secret": os.environ.get("THREECX_CLIENT_SECRET", ""),
        }
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE) as f:
            return json.load(f)
    return {}

def save_config(config):
    """Save config to file (only when not using env vars)."""
    if os.environ.get("THREECX_FQDN"):
        return  # Using env vars, don't write file
    with open(CONFIG_FILE, "w") as f:
        json.dump(config, f, indent=2)
    os.chmod(CONFIG_FILE, 0o600)

def get_token(fqdn, client_id, client_secret):
    url = f"https://{fqdn}/connect/token"
    data = {
        "client_id": client_id,
        "client_secret": client_secret,
        "grant_type": "client_credentials"
    }
    resp = requests.post(url, data=data)
    resp.raise_for_status()
    return resp.json()

def get_headers(config):
    now = time.time()
    if config.get("access_token") and config.get("token_expiry", 0) > now + 5:
        token = config["access_token"]
    else:
        token_data = get_token(config["fqdn"], config["client_id"], config["client_secret"])
        config["access_token"] = token_data["access_token"]
        config["token_expiry"] = now + token_data.get("expires_in", 3600)
        save_config(config)
        token = config["access_token"]
    return {"Authorization": f"Bearer {token}", "Content-Type": "application/json"}

def api_url(config, path):
    return f"https://{config['fqdn']}/xapi/v1/{path}"

def handle_response(resp):
    if resp.status_code >= 400:
        print(f"Error {resp.status_code}: {resp.text}", file=sys.stderr)
        sys.exit(1)
    if resp.text:
        try:
            print(json.dumps(resp.json(), indent=2))
        except (json.JSONDecodeError, requests.exceptions.JSONDecodeError):
            print(resp.text)
    else:
        print(f"Success: {resp.status_code}")

def add_list_args(parser):
    """Add --top/--skip/--filter to any list subcommand."""
    parser.add_argument("--top", type=int, default=100, help="Max items to return")
    parser.add_argument("--skip", type=int, default=0, help="Items to skip")
    parser.add_argument("--filter", dest="odata_filter", help="OData $filter expression")

def build_list_params(args):
    """Build OData query dict from parsed args."""
    params = {"$top": args.top, "$skip": args.skip, "$orderby": "Id"}
    if hasattr(args, "odata_filter") and args.odata_filter:
        params["$filter"] = args.odata_filter
    return params

